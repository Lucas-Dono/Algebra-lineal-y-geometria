---
interface Props {
  youtubeId: string;
  title?: string;
  start?: number;
  end?: number;
}

const { youtubeId, title, start, end } = Astro.props;

let embedUrl = `https://www.youtube.com/embed/${youtubeId}`;
const params = new URLSearchParams();

if (start) params.append('start', start.toString());
if (end) params.append('end', end.toString());

if (params.toString()) {
  embedUrl += `?${params.toString()}`;
}
---

<div class="my-8">
  {title && (
    <h4 class="font-medium text-base-content/80 mb-3 flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-500" viewBox="0 0 24 24" fill="currentColor">
        <path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/>
      </svg>
      {title}
    </h4>
  )}
  <div class="relative w-full aspect-video rounded-xl overflow-hidden bg-base-300">
    <iframe
      src={embedUrl}
      title={title || 'Video de YouTube'}
      frameborder="0"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
      loading="lazy"
      class="absolute inset-0 w-full h-full"
    ></iframe>
  </div>
</div>
