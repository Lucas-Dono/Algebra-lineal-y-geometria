{
  "chapter": "06-determinantes",
  "exercises": [
    {
      "id": "det-06-prac-01",
      "type": "practice",
      "question": {
        "text": "Calcular el determinante de A = [[3,1,2],[0,4,5],[0,0,6]] usando propiedades",
        "latex": "A = \\begin{pmatrix} 3 & 1 & 2 \\\\ 0 & 4 & 5 \\\\ 0 & 0 & 6 \\end{pmatrix}"
      },
      "solution": {
        "text": "det(A) = 72",
        "latex": "\\det(A) = 72",
        "steps": [
          "A es triangular superior",
          "El determinante de una triangular es el producto de la diagonal",
          "det(A) = 3 * 4 * 6 = 72"
        ]
      },
      "hints": [
        "Observa la estructura de la matriz",
        "Es triangular superior"
      ],
      "tags": ["determinantes", "triangular"],
      "difficulty": "easy"
    },
    {
      "id": "det-06-prac-02",
      "type": "practice",
      "question": {
        "text": "Calcular det(A) donde A = [[1,2,3],[4,5,6],[7,8,9]] usando la regla de Sarrus",
        "latex": "A = \\begin{pmatrix} 1 & 2 & 3 \\\\ 4 & 5 & 6 \\\\ 7 & 8 & 9 \\end{pmatrix}"
      },
      "solution": {
        "text": "det(A) = 0",
        "latex": "\\det(A) = 0",
        "steps": [
          "Diagonales positivas: 1*5*9 + 2*6*7 + 3*4*8 = 45 + 84 + 96 = 225",
          "Diagonales negativas: 3*5*7 + 1*6*8 + 2*4*9 = 105 + 48 + 72 = 225",
          "det(A) = 225 - 225 = 0",
          "Nota: la tercera fila es suma de las otras dos, por eso det = 0"
        ]
      },
      "hints": [
        "Aplica la regla de Sarrus para 3x3",
        "Suma de diagonales principales menos suma de diagonales secundarias"
      ],
      "tags": ["determinantes", "sarrus"],
      "difficulty": "medium"
    },
    {
      "id": "det-06-prac-03",
      "type": "practice",
      "question": {
        "text": "Usar la regla de Cramer para resolver: 2x + y = 5, x - 3y = -1",
        "latex": "\\begin{cases} 2x + y = 5 \\\\ x - 3y = -1 \\end{cases}"
      },
      "solution": {
        "text": "x = 2, y = 1",
        "latex": "x = 2, \\quad y = 1",
        "steps": [
          "A = [[2,1],[1,-3]], det(A) = 2(-3) - 1(1) = -7",
          "A1 = [[5,1],[-1,-3]], det(A1) = 5(-3) - 1(-1) = -14",
          "A2 = [[2,5],[1,-1]], det(A2) = 2(-1) - 5(1) = -7",
          "x = det(A1)/det(A) = -14/-7 = 2",
          "y = det(A2)/det(A) = -7/-7 = 1",
          "Verificacion: 2(2) + 1 = 5 OK, 2 - 3(1) = -1 OK"
        ]
      },
      "hints": [
        "det(A) es el determinante del sistema",
        "Reemplaza cada columna por el vector b para obtener A1, A2"
      ],
      "tags": ["determinantes", "cramer"],
      "difficulty": "medium"
    },
    {
      "id": "det-06-prac-04",
      "type": "practice",
      "question": {
        "text": "Calcular el area del triangulo con vertices (0,0), (3,0), (1,4)",
        "latex": null
      },
      "solution": {
        "text": "Area = 6",
        "latex": "\\text{Area} = 6",
        "steps": [
          "Usando la formula del determinante:",
          "Area = (1/2)|det([[0,0,1],[3,0,1],[1,4,1]])|",
          "= (1/2)|0(0-4) - 0(3-1) + 1(12-0)|",
          "= (1/2)|12| = 6",
          "Alternativa: vectores desde (0,0): (3,0) y (1,4)",
          "Area = (1/2)|det([[3,1],[0,4]])| = (1/2)|12| = 6"
        ]
      },
      "hints": [
        "El area de un triangulo es la mitad del area del paralelogramo",
        "Usa el determinante de los vectores desde un vertice"
      ],
      "tags": ["determinantes", "geometria", "area"],
      "difficulty": "medium"
    }
  ]
}
