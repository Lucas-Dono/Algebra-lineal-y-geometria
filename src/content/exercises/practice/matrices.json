{
  "chapter": "05-matrices",
  "exercises": [
    {
      "id": "mat-05-prac-01",
      "type": "practice",
      "question": {
        "text": "Calcular AB donde A = [[1,2],[3,4]] y B = [[5,6],[7,8]]",
        "latex": "A = \\begin{pmatrix} 1 & 2 \\\\ 3 & 4 \\end{pmatrix}, \\quad B = \\begin{pmatrix} 5 & 6 \\\\ 7 & 8 \\end{pmatrix}"
      },
      "solution": {
        "text": "AB = [[1*5+2*7, 1*6+2*8], [3*5+4*7, 3*6+4*8]] = [[19, 22], [43, 50]]",
        "latex": "AB = \\begin{pmatrix} 1(5)+2(7) & 1(6)+2(8) \\\\ 3(5)+4(7) & 3(6)+4(8) \\end{pmatrix} = \\begin{pmatrix} 19 & 22 \\\\ 43 & 50 \\end{pmatrix}",
        "steps": [
          "Elemento (1,1): 1*5 + 2*7 = 5 + 14 = 19",
          "Elemento (1,2): 1*6 + 2*8 = 6 + 16 = 22",
          "Elemento (2,1): 3*5 + 4*7 = 15 + 28 = 43",
          "Elemento (2,2): 3*6 + 4*8 = 18 + 32 = 50"
        ]
      },
      "hints": [
        "Cada elemento (i,j) es el producto punto de fila i de A con columna j de B"
      ],
      "tags": ["matrices", "multiplicacion"],
      "difficulty": "easy"
    },
    {
      "id": "mat-05-prac-02",
      "type": "practice",
      "question": {
        "text": "Encontrar la inversa de A = [[2,1],[5,3]] usando el metodo de Gauss-Jordan",
        "latex": "A = \\begin{pmatrix} 2 & 1 \\\\ 5 & 3 \\end{pmatrix}"
      },
      "solution": {
        "text": "A^(-1) = [[3,-1],[-5,2]]",
        "latex": "A^{-1} = \\begin{pmatrix} 3 & -1 \\\\ -5 & 2 \\end{pmatrix}",
        "steps": [
          "Formar [A|I] = [[2,1|1,0],[5,3|0,1]]",
          "F2 -> F2 - (5/2)F1: [[2,1|1,0],[0,1/2|-5/2,1]]",
          "F2 -> 2*F2: [[2,1|1,0],[0,1|-5,2]]",
          "F1 -> F1 - F2: [[2,0|6,-2],[0,1|-5,2]]",
          "F1 -> (1/2)F1: [[1,0|3,-1],[0,1|-5,2]]",
          "La inversa es [[3,-1],[-5,2]]"
        ]
      },
      "hints": [
        "Forma la matriz aumentada [A|I]",
        "Reduce el lado izquierdo a I usando operaciones de fila"
      ],
      "tags": ["matrices", "inversa", "gauss-jordan"],
      "difficulty": "medium"
    },
    {
      "id": "mat-05-prac-03",
      "type": "practice",
      "question": {
        "text": "Calcular el rango de A = [[1,2,3],[2,4,6],[1,1,1]]",
        "latex": "A = \\begin{pmatrix} 1 & 2 & 3 \\\\ 2 & 4 & 6 \\\\ 1 & 1 & 1 \\end{pmatrix}"
      },
      "solution": {
        "text": "rango(A) = 2",
        "latex": "\\text{rango}(A) = 2",
        "steps": [
          "F2 -> F2 - 2F1: [[1,2,3],[0,0,0],[1,1,1]]",
          "F3 -> F3 - F1: [[1,2,3],[0,0,0],[0,-1,-2]]",
          "Intercambiar F2 y F3: [[1,2,3],[0,-1,-2],[0,0,0]]",
          "Hay 2 filas no nulas (2 pivotes)",
          "Por lo tanto, rango(A) = 2"
        ]
      },
      "hints": [
        "Reduce a forma escalonada",
        "Cuenta el numero de filas no nulas (pivotes)"
      ],
      "tags": ["matrices", "rango"],
      "difficulty": "medium"
    },
    {
      "id": "mat-05-prac-04",
      "type": "practice",
      "question": {
        "text": "Verificar que (AB)^T = B^T A^T para A = [[1,2],[3,4]] y B = [[0,1],[2,3]]",
        "latex": null
      },
      "solution": {
        "text": "Ambos lados dan [[4,14],[5,17]]",
        "latex": "(AB)^T = B^T A^T = \\begin{pmatrix} 4 & 14 \\\\ 5 & 17 \\end{pmatrix}",
        "steps": [
          "Calcular AB = [[4,7],[8,15]]",
          "(AB)^T = [[4,8],[7,15]]... Espera, recalculemos:",
          "AB = [[1*0+2*2, 1*1+2*3],[3*0+4*2, 3*1+4*3]] = [[4,7],[8,15]]",
          "(AB)^T = [[4,8],[7,15]]",
          "A^T = [[1,3],[2,4]], B^T = [[0,2],[1,3]]",
          "B^T A^T = [[0*1+2*2, 0*3+2*4],[1*1+3*2, 1*3+3*4]] = [[4,8],[7,15]]",
          "Ambos son iguales: [[4,8],[7,15]]"
        ]
      },
      "hints": [
        "Calcula primero AB y luego su transpuesta",
        "Calcula B^T, A^T y su producto"
      ],
      "tags": ["matrices", "transpuesta"],
      "difficulty": "medium"
    }
  ]
}
