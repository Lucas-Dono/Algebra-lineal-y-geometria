{
  "chapter": "08-autovalores-autovectores",
  "exercises": [
    {
      "id": "av-08-view-01",
      "type": "view",
      "title": "Calcular autovalores y autovectores",
      "question": {
        "text": "Encontrar los autovalores y autovectores de A",
        "latex": "A = \\begin{pmatrix} 4 & 2 \\\\ 1 & 3 \\end{pmatrix}"
      },
      "solution": {
        "steps": [
          {
            "title": "Escribir la ecuacion caracteristica",
            "explanation": "det(A - lambda I) = 0",
            "latex": "\\det\\begin{pmatrix} 4-\\lambda & 2 \\\\ 1 & 3-\\lambda \\end{pmatrix} = 0"
          },
          {
            "title": "Expandir el determinante",
            "explanation": "Calculamos el polinomio caracteristico",
            "latex": "(4-\\lambda)(3-\\lambda) - 2(1) = \\lambda^2 - 7\\lambda + 12 - 2 = \\lambda^2 - 7\\lambda + 10"
          },
          {
            "title": "Factorizar",
            "explanation": "Buscamos raices del polinomio",
            "latex": "\\lambda^2 - 7\\lambda + 10 = (\\lambda - 5)(\\lambda - 2) = 0"
          },
          {
            "title": "Autovalores",
            "explanation": "Las raices son los autovalores",
            "latex": "\\lambda_1 = 5, \\quad \\lambda_2 = 2"
          },
          {
            "title": "Autovector para lambda = 5",
            "explanation": "Resolver (A - 5I)v = 0",
            "latex": "\\begin{pmatrix} -1 & 2 \\\\ 1 & -2 \\end{pmatrix} \\begin{pmatrix} x \\\\ y \\end{pmatrix} = \\begin{pmatrix} 0 \\\\ 0 \\end{pmatrix} \\Rightarrow -x + 2y = 0 \\Rightarrow x = 2y"
          },
          {
            "title": "Autovector v1",
            "explanation": "Elegimos y = 1",
            "latex": "\\mathbf{v}_1 = \\begin{pmatrix} 2 \\\\ 1 \\end{pmatrix}"
          },
          {
            "title": "Autovector para lambda = 2",
            "explanation": "Resolver (A - 2I)v = 0",
            "latex": "\\begin{pmatrix} 2 & 2 \\\\ 1 & 1 \\end{pmatrix} \\begin{pmatrix} x \\\\ y \\end{pmatrix} = \\begin{pmatrix} 0 \\\\ 0 \\end{pmatrix} \\Rightarrow x + y = 0 \\Rightarrow y = -x"
          },
          {
            "title": "Autovector v2",
            "explanation": "Elegimos x = 1",
            "latex": "\\mathbf{v}_2 = \\begin{pmatrix} 1 \\\\ -1 \\end{pmatrix}"
          }
        ],
        "final_answer": {
          "text": "Autovalores: 5 y 2 con sus respectivos autovectores",
          "latex": "\\lambda_1 = 5, \\mathbf{v}_1 = \\begin{pmatrix} 2 \\\\ 1 \\end{pmatrix}; \\quad \\lambda_2 = 2, \\mathbf{v}_2 = \\begin{pmatrix} 1 \\\\ -1 \\end{pmatrix}"
        }
      },
      "key_concepts": ["polinomio caracteristico", "autovalores", "autovectores"],
      "difficulty": "medium"
    },
    {
      "id": "av-08-view-02",
      "type": "view",
      "title": "Diagonalizacion de matriz",
      "question": {
        "text": "Diagonalizar la matriz A",
        "latex": "A = \\begin{pmatrix} 1 & 2 \\\\ 0 & 3 \\end{pmatrix}"
      },
      "solution": {
        "steps": [
          {
            "title": "Encontrar autovalores",
            "explanation": "A es triangular, los autovalores estan en la diagonal",
            "latex": "\\lambda_1 = 1, \\quad \\lambda_2 = 3"
          },
          {
            "title": "Autovector para lambda = 1",
            "explanation": "Resolver (A - I)v = 0",
            "latex": "\\begin{pmatrix} 0 & 2 \\\\ 0 & 2 \\end{pmatrix} \\mathbf{v} = \\mathbf{0} \\Rightarrow 2y = 0 \\Rightarrow \\mathbf{v}_1 = \\begin{pmatrix} 1 \\\\ 0 \\end{pmatrix}"
          },
          {
            "title": "Autovector para lambda = 3",
            "explanation": "Resolver (A - 3I)v = 0",
            "latex": "\\begin{pmatrix} -2 & 2 \\\\ 0 & 0 \\end{pmatrix} \\mathbf{v} = \\mathbf{0} \\Rightarrow -2x + 2y = 0 \\Rightarrow \\mathbf{v}_2 = \\begin{pmatrix} 1 \\\\ 1 \\end{pmatrix}"
          },
          {
            "title": "Formar matriz P",
            "explanation": "Las columnas son los autovectores",
            "latex": "P = \\begin{pmatrix} 1 & 1 \\\\ 0 & 1 \\end{pmatrix}"
          },
          {
            "title": "Formar matriz D",
            "explanation": "Diagonal con los autovalores",
            "latex": "D = \\begin{pmatrix} 1 & 0 \\\\ 0 & 3 \\end{pmatrix}"
          },
          {
            "title": "Calcular P^(-1)",
            "explanation": "Inversa de P",
            "latex": "P^{-1} = \\begin{pmatrix} 1 & -1 \\\\ 0 & 1 \\end{pmatrix}"
          },
          {
            "title": "Verificar diagonalizacion",
            "explanation": "A = PDP^(-1)",
            "latex": "PDP^{-1} = \\begin{pmatrix} 1 & 1 \\\\ 0 & 1 \\end{pmatrix} \\begin{pmatrix} 1 & 0 \\\\ 0 & 3 \\end{pmatrix} \\begin{pmatrix} 1 & -1 \\\\ 0 & 1 \\end{pmatrix} = A \\checkmark"
          }
        ],
        "final_answer": {
          "text": "La matriz es diagonalizable con A = PDP^(-1)",
          "latex": "A = \\begin{pmatrix} 1 & 1 \\\\ 0 & 1 \\end{pmatrix} \\begin{pmatrix} 1 & 0 \\\\ 0 & 3 \\end{pmatrix} \\begin{pmatrix} 1 & -1 \\\\ 0 & 1 \\end{pmatrix}"
        }
      },
      "key_concepts": ["diagonalizacion", "matriz de paso", "matriz diagonal"],
      "difficulty": "medium"
    },
    {
      "id": "av-08-view-03",
      "type": "view",
      "title": "Potencia de matriz usando diagonalizacion",
      "question": {
        "text": "Calcular A^10 sabiendo que A es diagonalizable",
        "latex": "A = \\begin{pmatrix} 2 & 1 \\\\ 0 & 1 \\end{pmatrix}"
      },
      "solution": {
        "steps": [
          {
            "title": "Autovalores",
            "explanation": "Diagonal de matriz triangular",
            "latex": "\\lambda_1 = 2, \\quad \\lambda_2 = 1"
          },
          {
            "title": "Autovectores",
            "explanation": "Calculamos los autovectores",
            "latex": "\\mathbf{v}_1 = \\begin{pmatrix} 1 \\\\ 0 \\end{pmatrix}, \\quad \\mathbf{v}_2 = \\begin{pmatrix} 1 \\\\ -1 \\end{pmatrix}"
          },
          {
            "title": "Matrices P y D",
            "explanation": "P con autovectores, D diagonal",
            "latex": "P = \\begin{pmatrix} 1 & 1 \\\\ 0 & -1 \\end{pmatrix}, \\quad D = \\begin{pmatrix} 2 & 0 \\\\ 0 & 1 \\end{pmatrix}"
          },
          {
            "title": "P^(-1)",
            "explanation": "Inversa de P",
            "latex": "P^{-1} = \\begin{pmatrix} 1 & 1 \\\\ 0 & -1 \\end{pmatrix}"
          },
          {
            "title": "Formula para A^n",
            "explanation": "Si A = PDP^(-1), entonces A^n = PD^nP^(-1)",
            "latex": "A^{10} = PD^{10}P^{-1}"
          },
          {
            "title": "Calcular D^10",
            "explanation": "Solo elevamos la diagonal",
            "latex": "D^{10} = \\begin{pmatrix} 2^{10} & 0 \\\\ 0 & 1^{10} \\end{pmatrix} = \\begin{pmatrix} 1024 & 0 \\\\ 0 & 1 \\end{pmatrix}"
          },
          {
            "title": "Calcular A^10",
            "explanation": "Multiplicamos PD^10 P^(-1)",
            "latex": "A^{10} = \\begin{pmatrix} 1 & 1 \\\\ 0 & -1 \\end{pmatrix} \\begin{pmatrix} 1024 & 0 \\\\ 0 & 1 \\end{pmatrix} \\begin{pmatrix} 1 & 1 \\\\ 0 & -1 \\end{pmatrix}"
          },
          {
            "title": "Resultado intermedio",
            "explanation": "PD^10",
            "latex": "PD^{10} = \\begin{pmatrix} 1024 & 1 \\\\ 0 & -1 \\end{pmatrix}"
          },
          {
            "title": "Resultado final",
            "explanation": "Multiplicamos por P^(-1)",
            "latex": "A^{10} = \\begin{pmatrix} 1024 & 1 \\\\ 0 & -1 \\end{pmatrix} \\begin{pmatrix} 1 & 1 \\\\ 0 & -1 \\end{pmatrix} = \\begin{pmatrix} 1024 & 1023 \\\\ 0 & 1 \\end{pmatrix}"
          }
        ],
        "final_answer": {
          "text": "A elevada a la decima potencia",
          "latex": "A^{10} = \\begin{pmatrix} 1024 & 1023 \\\\ 0 & 1 \\end{pmatrix}"
        }
      },
      "key_concepts": ["potencia de matriz", "diagonalizacion", "A^n = PD^nP^(-1)"],
      "difficulty": "hard"
    }
  ]
}
