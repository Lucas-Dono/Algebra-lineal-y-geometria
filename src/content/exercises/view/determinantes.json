{
  "chapter": "06-determinantes",
  "exercises": [
    {
      "id": "det-06-view-01",
      "type": "view",
      "title": "Determinante 3x3 por regla de Sarrus",
      "question": {
        "text": "Calcular el determinante usando la regla de Sarrus",
        "latex": "A = \\begin{pmatrix} 2 & 1 & 3 \\\\ 0 & 4 & 1 \\\\ 1 & 2 & 5 \\end{pmatrix}"
      },
      "solution": {
        "steps": [
          {
            "title": "Duplicar las dos primeras columnas",
            "explanation": "Para aplicar Sarrus, escribimos la matriz con las columnas 1 y 2 repetidas a la derecha",
            "latex": "\\begin{array}{ccc|cc} 2 & 1 & 3 & 2 & 1 \\\\ 0 & 4 & 1 & 0 & 4 \\\\ 1 & 2 & 5 & 1 & 2 \\end{array}"
          },
          {
            "title": "Diagonales principales (suman)",
            "explanation": "Tres diagonales de izquierda a derecha, hacia abajo",
            "latex": "\\begin{aligned} d_1 &= 2 \\cdot 4 \\cdot 5 = 40 \\\\ d_2 &= 1 \\cdot 1 \\cdot 1 = 1 \\\\ d_3 &= 3 \\cdot 0 \\cdot 2 = 0 \\end{aligned}"
          },
          {
            "title": "Diagonales secundarias (restan)",
            "explanation": "Tres diagonales de derecha a izquierda, hacia abajo",
            "latex": "\\begin{aligned} d_4 &= 3 \\cdot 4 \\cdot 1 = 12 \\\\ d_5 &= 2 \\cdot 1 \\cdot 2 = 4 \\\\ d_6 &= 1 \\cdot 0 \\cdot 5 = 0 \\end{aligned}"
          },
          {
            "title": "Aplicar la formula",
            "explanation": "Suma de principales menos suma de secundarias",
            "latex": "\\det(A) = (40 + 1 + 0) - (12 + 4 + 0) = 41 - 16 = 25"
          }
        ],
        "final_answer": {
          "text": "El determinante es 25",
          "latex": "\\det(A) = 25"
        }
      },
      "key_concepts": ["regla de Sarrus", "determinante 3x3"],
      "difficulty": "easy"
    },
    {
      "id": "det-06-view-02",
      "type": "view",
      "title": "Determinante por expansion de cofactores",
      "question": {
        "text": "Calcular el determinante expandiendo por la primera columna",
        "latex": "A = \\begin{pmatrix} 3 & 0 & 2 \\\\ 1 & 4 & 5 \\\\ 2 & 1 & 6 \\end{pmatrix}"
      },
      "solution": {
        "steps": [
          {
            "title": "Formula de expansion por columna",
            "explanation": "Expandimos por la columna 1: det(A) = sum a_{i1} C_{i1}",
            "latex": "\\det(A) = a_{11}C_{11} + a_{21}C_{21} + a_{31}C_{31}"
          },
          {
            "title": "Calcular cofactor C_11",
            "explanation": "C_11 = (-1)^(1+1) M_11, donde M_11 es el menor",
            "latex": "C_{11} = (+1) \\begin{vmatrix} 4 & 5 \\\\ 1 & 6 \\end{vmatrix} = 4(6) - 5(1) = 19"
          },
          {
            "title": "Calcular cofactor C_21",
            "explanation": "C_21 = (-1)^(2+1) M_21",
            "latex": "C_{21} = (-1) \\begin{vmatrix} 0 & 2 \\\\ 1 & 6 \\end{vmatrix} = -(0(6) - 2(1)) = -(-2) = 2"
          },
          {
            "title": "Calcular cofactor C_31",
            "explanation": "C_31 = (-1)^(3+1) M_31",
            "latex": "C_{31} = (+1) \\begin{vmatrix} 0 & 2 \\\\ 4 & 5 \\end{vmatrix} = 0(5) - 2(4) = -8"
          },
          {
            "title": "Sumar contribuciones",
            "explanation": "Multiplicamos cada elemento por su cofactor",
            "latex": "\\det(A) = 3(19) + 1(2) + 2(-8) = 57 + 2 - 16 = 43"
          }
        ],
        "final_answer": {
          "text": "El determinante es 43",
          "latex": "\\det(A) = 43"
        }
      },
      "key_concepts": ["expansion de cofactores", "menores", "cofactores"],
      "difficulty": "medium"
    },
    {
      "id": "det-06-view-03",
      "type": "view",
      "title": "Sistema 3x3 por regla de Cramer",
      "question": {
        "text": "Resolver el sistema usando la regla de Cramer",
        "latex": "\\begin{cases} x + y + z = 6 \\\\ 2x - y + z = 3 \\\\ x + y - z = 0 \\end{cases}"
      },
      "solution": {
        "steps": [
          {
            "title": "Calcular det(A)",
            "explanation": "Determinante de la matriz de coeficientes",
            "latex": "A = \\begin{pmatrix} 1 & 1 & 1 \\\\ 2 & -1 & 1 \\\\ 1 & 1 & -1 \\end{pmatrix}, \\quad \\det(A) = 1(0) - 1(-3) + 1(3) = 6"
          },
          {
            "title": "Calcular det(A_x)",
            "explanation": "Reemplazamos la columna 1 por el vector b",
            "latex": "A_x = \\begin{pmatrix} 6 & 1 & 1 \\\\ 3 & -1 & 1 \\\\ 0 & 1 & -1 \\end{pmatrix}, \\quad \\det(A_x) = 6(0) - 1(-3) + 1(3) = 6"
          },
          {
            "title": "Calcular det(A_y)",
            "explanation": "Reemplazamos la columna 2 por el vector b",
            "latex": "A_y = \\begin{pmatrix} 1 & 6 & 1 \\\\ 2 & 3 & 1 \\\\ 1 & 0 & -1 \\end{pmatrix}, \\quad \\det(A_y) = 1(-3) - 6(-3) + 1(-3) = 12"
          },
          {
            "title": "Calcular det(A_z)",
            "explanation": "Reemplazamos la columna 3 por el vector b",
            "latex": "A_z = \\begin{pmatrix} 1 & 1 & 6 \\\\ 2 & -1 & 3 \\\\ 1 & 1 & 0 \\end{pmatrix}, \\quad \\det(A_z) = 1(-3) - 1(-3) + 6(3) = 18"
          },
          {
            "title": "Aplicar formulas de Cramer",
            "explanation": "x = det(A_x)/det(A), etc.",
            "latex": "x = \\frac{6}{6} = 1, \\quad y = \\frac{12}{6} = 2, \\quad z = \\frac{18}{6} = 3"
          },
          {
            "title": "Verificacion",
            "explanation": "Sustituimos en las ecuaciones originales",
            "latex": "\\begin{aligned} 1 + 2 + 3 &= 6 \\checkmark \\\\ 2(1) - 2 + 3 &= 3 \\checkmark \\\\ 1 + 2 - 3 &= 0 \\checkmark \\end{aligned}"
          }
        ],
        "final_answer": {
          "text": "La solucion es (1, 2, 3)",
          "latex": "(x, y, z) = (1, 2, 3)"
        }
      },
      "key_concepts": ["regla de Cramer", "determinantes", "sistemas lineales"],
      "difficulty": "medium"
    }
  ]
}
